{
  "name": "apifier-orchestray-plugin",
  "version": "0.5.0",
  "description": "Orchestray plugin: scrape API documentation into a portable mapping file, then generate language-specific client modules.",
  "keywords": [
    "orchestray",
    "orchestray-plugin",
    "api",
    "openapi",
    "swagger",
    "codegen",
    "client-generator",
    "mcp",
    "mcp-server"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/palginpav/apifier-orchestray-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/palginpav/apifier-orchestray-plugin/issues"
  },
  "homepage": "https://github.com/palginpav/apifier-orchestray-plugin#readme",
  "author": "Pavel Palgin",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "apifier-doctor": "bin/apifier-doctor.js"
  },
  "files": [
    "orchestray-plugin.json",
    "server.js",
    "lib/",
    "bin/apifier-doctor.js",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "node --test 'tests/**/*.test.js'",
    "doctor": "node bin/apifier-doctor.js",
    "pack:dry": "npm pack --dry-run"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "js-yaml": "^4.1.1",
    "zod": "^4.4.3"
  }
}
