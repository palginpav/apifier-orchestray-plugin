# .npmignore — Files excluded from npm publish.
# Note: package.json `files` is an allowlist that takes precedence; this list
# is a belt-and-braces fallback. Keep both in sync to avoid maintainer confusion.
tests/
.orchestray/
.git*
task.md
.claude/
coverage/
.nyc_output/
*.log
.DS_Store
docs/
__pycache__/
